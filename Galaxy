clearAllBtn.MouseButton1Click:Connect(function()
    if #customButtons == 0 then showNotif("⚠️ No buttons to clear!", Color3.fromRGB(180,120,20)) return end
    for _,data in ipairs(customButtons) do
        table.insert(undoStack, {
            id=data.id, name=data.name, script=data.script, color=data.color,
            textColor=data.textColor, width=data.width, icon=data.icon,
            tooltip=data.tooltip, hotkey=data.hotkey, tag=data.tag
        })
        if data.floatingBtn and data.floatingBtn.Parent then data.floatingBtn:Destroy() end
        if data.container and data.container.Parent then data.container:Destroy() end
    end
    while #undoStack > 15 do table.remove(undoStack,1) end
    customButtons = {}
    floatingBtns = {}
    hotkeys = {}
    pinnedButtons = {}
    redoStack = {}
    updateScroll()
    updateHotkeyList()
    updatePinBar()
    refreshGroupBar()
    showNotif("🗑️ All buttons cleared!", Color3.fromRGB(148,16,52))
end)

