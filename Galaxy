LocalPlayer.CharacterAdded:Connect(function()
    task.wait(1.5)
    if autoReaddTog.get() then
        for _, td in pairs(toolsList) do
            if td.tool then
                td.tool.Parent = LocalPlayer.Backpack
                forceVisible(td.tool)
            end
        end
        if #toolsList > 0 then
            task.spawn(showNotif, "🔄 " .. #toolsList .. " tool dikembalikan ke backpack!", Color3.fromRGB(140, 255, 165))
        end
    end
end)

RunService.Heartbeat:Connect(function()
    ScreenGui.Enabled = true
    ToggleBtn.Visible = true

    local t = tick()
    tStroke.Thickness = 2 + (math.sin(t * 2.5) + 1)
    mStroke.Thickness = 2 + (math.sin(t * 1.8 + 1) + 1) * 0.4

    local inBagCount = 0
    for _, td in pairs(toolsList) do
        if td.tool and td.tool.Parent then
            if forceVisTog.get() then
                for _, v in pairs(td.tool:GetDescendants()) do
                    if v:IsA("BasePart") then
                        if v.Transparency ~= 0 then v.Transparency = 0 end
                        if v.LocalTransparencyModifier ~= 0 then v.LocalTransparencyModifier = 0 end
                    end
                end
            end
            if td.tool.Parent == LocalPlayer.Backpack or td.tool.Parent == LocalPlayer.Character then
                inBagCount = inBagCount + 1
            end
        end
    end

    statsLabel.Text = "Total Tools: " .. #toolsList .. "\nTools di Backpack: " .. inBagCount
end)

