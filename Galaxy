local function buildTool()
    local tName = nameInput.Text
    if tName == "" then
        statusCreate.Text = "⚠️ Nama tool tidak boleh kosong!"
        statusCreate.TextColor3 = Color3.fromRGB(255, 100, 100)
        task.spawn(showNotif, "⚠️ Nama tool tidak boleh kosong!", Color3.fromRGB(255, 100, 100))
        return
    end

    local col = colorPick.get()
    local tool = Instance.new("Tool")
    tool.Name = tName
    tool.ToolTip = typeInput.Text ~= "" and typeInput.Text or tName
    tool.RequiresHandle = true
    tool.CanBeDropped = true
    tool.GripPos = Vector3.new(0, 0, -1)

    local handle = Instance.new("Part", tool)
    handle.Name = "Handle"
    handle.Size = Vector3.new(sX.get(), sY.get(), sZ.get())
    handle.Color = col
    handle.BrickColor = BrickColor.new(col)
    handle.Material = getMat(matInput.Text)
    handle.Transparency = 0
    handle.CastShadow = true

    applyFx(handle, col)

    if soundInput.Text ~= "" and tonumber(soundInput.Text) then
        local snd = Instance.new("Sound", handle)
        snd.Name = "EquipSound"
        snd.SoundId = "rbxassetid://" .. soundInput.Text
        snd.Volume = 1
    end

    local cfg = Instance.new("Configuration", tool)
    cfg.Name = "ToolData"
    local vals = {
        {n="ToolName", v=tName, t="StringValue"},
        {n="ToolType", v=typeInput.Text, t="StringValue"},
        {n="Tag", v=tagInput.Text, t="StringValue"},
        {n="Damage", v=dmgSlider.get(), t="NumberValue"},
        {n="SpeedBonus", v=spdSlider.get(), t="NumberValue"},
        {n="Range", v=rangeSlider.get(), t="NumberValue"},
        {n="Cooldown", v=cdSlider.get()/10, t="NumberValue"},
        {n="Durability", v=durSlider.get(), t="NumberValue"},
        {n="CreatedAt", v=os.time(), t="NumberValue"},
        {n="ColorR", v=col.R, t="NumberValue"},
        {n="ColorG", v=col.G, t="NumberValue"},
        {n="ColorB", v=col.B, t="NumberValue"},
    }
    for _, vd in pairs(vals) do
        local sv = Instance.new(vd.t, cfg)
        sv.Name = vd.n
        sv.Value = vd.v
    end

    local ls = Instance.new("LocalScript", tool)
    ls.Name = "ToolController"
    ls.Source = string.format([[
local tool = script.Parent
local RunService = game:GetService("RunService")
local isEquipped = false
local lastUsed = 0
local cd = %f

local function keepVis()
    for _, v in pairs(tool:GetDescendants()) do
        if v:IsA("BasePart") then
            v.Transparency = 0
            v.LocalTransparencyModifier = 0
        end
    end
end

RunService.Heartbeat:Connect(keepVis)

tool.Equipped:Connect(function()
    isEquipped = true
    keepVis()
    local s = tool:FindFirstChild("Handle") and tool.Handle:FindFirstChild("EquipSound")
    if s then s:Play() end
end)

tool.Unequipped:Connect(function()
    isEquipped = false
end)

tool.Activated:Connect(function()
    if not isEquipped then return end
    local now = tick()
    if now - lastUsed < cd then return end
    lastUsed = now
    keepVis()
end)

tool.DescendantAdded:Connect(function(v)
    task.wait()
    if v:IsA("BasePart") then
        v.Transparency = 0
        v.LocalTransparencyModifier = 0
    end
end)
]], cdSlider.get()/10)

    tool.Parent = LocalPlayer.Backpack
    forceVisible(tool)

    local entry = {
        name = tName,
        tool = tool,
        type = typeInput.Text,
        tag = tagInput.Text,
        damage = dmgSlider.get(),
        speed = spdSlider.get(),
        range = rangeSlider.get(),
        cooldown = cdSlider.get()/10,
        durability = durSlider.get(),
        color = col,
        material = matInput.Text,
        created = os.time(),
        glow = glowTog.get(),
        trail = trailTog.get(),
        sparkle = sparkleTog.get(),
        fire = fireTog.get(),
        smoke = smokeTog.get(),
        light = lightTog.get(),
    }
