local t = 0
local rainbowHue = 0
local fpsCount, fpsTimer, lastFPS = 0, 0, 0
local titleAnimT = 0

RunService.Heartbeat:Connect(function(dt)
    t = t + dt
    rainbowHue = (rainbowHue + dt * 0.065) % 1
    titleAnimT = titleAnimT + dt

    fpsTimer = fpsTimer + dt
    fpsCount = fpsCount + 1
    if fpsTimer >= 0.5 then
        lastFPS = math.floor(fpsCount / fpsTimer)
        fpsCount = 0
        fpsTimer = 0
        if getShowFPS() then
            fpsLabel.Text = "FPS: "..lastFPS
            fpsLabel.TextColor3 = lastFPS >= 55 and Color3.fromRGB(60,200,80) or lastFPS >= 30 and Color3.fromRGB(220,180,40) or Color3.fromRGB(220,50,50)
        end
    end

    toggleGrad.Rotation = (t * 34) % 360

    if getRainbow() then
        mainStroke.Color = Color3.fromHSV(rainbowHue, 0.88, 1)
        toggleStroke.Color = Color3.fromHSV((rainbowHue+0.33)%1, 0.88, 1)
        toggleDot.BackgroundColor3 = Color3.fromHSV(rainbowHue, 0.7, 1)
        titleIcon.TextColor3 = Color3.fromHSV((rainbowHue+0.12)%1, 0.7, 1)
        tabIndicator.BackgroundColor3 = Color3.fromHSV((rainbowHue+0.5)%1, 0.8, 1)
    else
        mainStroke.Color = Color3.fromHSV((t*0.062)%1, 0.62, 0.9)
        toggleStroke.Color = Color3.fromHSV(((t*0.062)+0.22)%1, 0.62, 0.9)
        titleIcon.TextColor3 = Color3.fromHSV((t*0.075)%1, 0.55, 1)
    end

    mainGrad.Rotation = (t * 9) % 360
    titleGrad.Rotation = (t * 18) % 360
    addGrad.Rotation = (t * 48) % 360

    local bounce = math.sin(titleAnimT * 2.5) * 0.5
    titleIcon.TextColor3 = Color3.fromHSV((t*0.08)%1, 0.5 + bounce*0.1, 1)

    if getStarAnim() then
        for i, s in ipairs(stars) do
            if s and s.Parent then
                s.BackgroundTransparency = 0.08 + 0.8*math.abs(math.sin(t*1.02 + i*0.48))
                s.BackgroundColor3 = Color3.fromHSV((t*0.035 + i*0.03)%1, 0.4, 1)
            end
        end
        nebula1.Position = UDim2.new(0.5 + math.sin(t*0.36)*0.055, -110, 0.22 + math.cos(t*0.27)*0.044, -110)
        nebula2.Position = UDim2.new(0.06 + math.cos(t*0.31)*0.038, 0, 0.6 + math.sin(t*0.4)*0.038, 0)
        nebula3.Position = UDim2.new(0.74 + math.sin(t*0.44)*0.028, 0, 0.68 + math.cos(t*0.34)*0.028, 0)
    end
end)

