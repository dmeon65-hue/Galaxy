local function getMat(name)
    local m = {
        smoothplastic=Enum.Material.SmoothPlastic, neon=Enum.Material.Neon,
        metal=Enum.Material.Metal, wood=Enum.Material.Wood,
        glass=Enum.Material.Glass, plastic=Enum.Material.Plastic,
        diamond=Enum.Material.DiamondPlate, brick=Enum.Material.Brick,
        cobblestone=Enum.Material.Cobblestone, slate=Enum.Material.Slate,
        granite=Enum.Material.Granite, marble=Enum.Material.Marble,
        fabric=Enum.Material.Fabric, ice=Enum.Material.Ice,
        sand=Enum.Material.Sand, foil=Enum.Material.Foil,
        crackedlava=Enum.Material.CrackedLava, corrodedmetal=Enum.Material.CorrodedMetal,
    }
    return m[string.lower(name or "")] or Enum.Material.SmoothPlastic
end

local function forceVisible(tool)
    local function fix(obj)
        if obj:IsA("BasePart") or obj:IsA("MeshPart") then
            obj.Transparency = 0
            obj.LocalTransparencyModifier = 0
        end
    end
    for _, v in pairs(tool:GetDescendants()) do fix(v) end
    tool.DescendantAdded:Connect(function(v) task.wait() fix(v) end)
end

local function applyFx(part, col)
    if glowTog.get() then part.Material = Enum.Material.Neon end
    if lightTog.get() then
        local pl = Instance.new("PointLight", part)
        pl.Brightness = 4
        pl.Range = 16
        pl.Color = col
    end
    if trailTog.get() then
        local a0 = Instance.new("Attachment", part)
        a0.Position = Vector3.new(0, 0.5, 0)
        local a1 = Instance.new("Attachment", part)
        a1.Position = Vector3.new(0, -0.5, 0)
        local tr = Instance.new("Trail", part)
        tr.Attachment0 = a0
        tr.Attachment1 = a1
        tr.Color = ColorSequence.new(col)
        tr.Lifetime = 0.6
        tr.LightEmission = 0.9
        tr.Transparency = NumberSequence.new({NumberSequenceKeypoint.new(0,0), NumberSequenceKeypoint.new(1,1)})
    end
    if sparkleTog.get() then
        local sp = Instance.new("Sparkles", part)
        sp.SparkleColor = col
    end
    if fireTog.get() then
        local f = Instance.new("Fire", part)
        f.Color = col
        f.SecondaryColor = Color3.fromRGB(255, 80, 0)
        f.Size = 3
        f.Heat = 8
    end
    if smokeTog.get() then
        local sm = Instance.new("Smoke", part)
        sm.Color = col
        sm.Opacity = 0.3
        sm.RiseVelocity = 5
    end
end

