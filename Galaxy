local function updatePinBar()
    for _,c in ipairs(pinScroll:GetChildren()) do
        if c:IsA("TextButton") then c:Destroy() end
    end
    local totalW = 0
    for _,pid in ipairs(pinnedButtons) do
        for _,data in ipairs(customButtons) do
            if data.id == pid then
                local pb = Instance.new("TextButton")
                pb.Size = UDim2.new(0, 0, 0, 22)
                pb.AutomaticSize = Enum.AutomaticSize.X
                pb.BackgroundColor3 = data.color
                pb.BorderSizePixel = 0
                pb.Text = " "..(data.icon ~= "" and data.icon.." " or "")..data.name.." "
                pb.TextColor3 = data.textColor
                pb.TextScaled = false
                pb.TextSize = 11
                pb.Font = Enum.Font.GothamBold
                pb.ZIndex = 5
                pb.Parent = pinScroll
                local pbc = Instance.new("UICorner"); pbc.CornerRadius = UDim.new(0,6); pbc.Parent = pb
                pb.MouseButton1Click:Connect(function()
                    local ok, err = pcall(function()
                        local fn = loadstring(data.script)
                        if fn then fn() end
                    end)
                    addHistoryEntry(data.name, ok, data.color)
                    if ok then showNotif("📌 "..data.name.." executed!", data.color)
                    else showNotif("❌ "..tostring(err):sub(1,35), Color3.fromRGB(200,40,40), 4) end
                    ripple(pb, UserInputService:GetMouseLocation().X, UserInputService:GetMouseLocation().Y)
                end)
                totalW = totalW + pb.AbsoluteSize.X + 3
                break
            end
        end
    end
    pinScroll.CanvasSize = UDim2.new(0, totalW + 10, 0, 0)
end

local function createCustomButton(cfg)
    local name = cfg.name or "Button"
    local script = cfg.script or 'print("Hello!")'
    local color = cfg.color or getT().accent
    local textColor = cfg.textColor or Color3.fromRGB(255,255,255)
    local width = math.clamp(tonumber(cfg.width) or 120, 60, 320) * buttonScale
    local icon = cfg.icon or ""
    local tooltip = cfg.tooltip or ""
    local hotkey = cfg.hotkey or ""
    local tag = cfg.tag or ""
    local id = cfg.id or HttpService:GenerateGUID(false)
    local displayName = (icon ~= "" and icon.." " or "")..name
    local rh = settings.compactMode and 28 or 38

    local container = Instance.new("Frame")
    container.Size = UDim2.new(1,-4,0,rh)
    container.BackgroundColor3 = getT().card
    container.BorderSizePixel = 0
    container.ZIndex = 4
    container.Parent = scrollFrame
    local contCr = Instance.new("UICorner"); contCr.CornerRadius = UDim.new(0,9); contCr.Parent = container
    local contS = Instance.new("UIStroke"); contS.Color = Color3.fromRGB(36,14,72); contS.Thickness = 1; contS.Parent = container

    if tag ~= "" then
        local tagBadge = Instance.new("TextLabel")
        tagBadge.Size = UDim2.new(0,0,0,12)
        tagBadge.AutomaticSize = Enum.AutomaticSize.X
        tagBadge.Position = UDim2.new(0,3,0,1)
        tagBadge.BackgroundColor3 = color
        tagBadge.BackgroundTransparency = 0.68
        tagBadge.BorderSizePixel = 0
        tagBadge.Text = " "..tag.." "
        tagBadge.TextColor3 = Color3.fromRGB(255,255,255)
        tagBadge.TextSize = 8
        tagBadge.Font = Enum.Font.GothamBold
        tagBadge.ZIndex = 6
        tagBadge.Parent = container
        local tbc2 = Instance.new("UICorner"); tbc2.CornerRadius = UDim.new(0,3); tbc2.Parent = tagBadge
    end

    local listBtn = Instance.new("TextButton")
    listBtn.Size = UDim2.new(0, width, 0, rh-8)
    listBtn.Position = UDim2.new(0, 4, 0.5, -(rh-8)/2)
    listBtn.BackgroundColor3 = color
    listBtn.BorderSizePixel = 0
    listBtn.Text = displayName
    listBtn.TextColor3 = textColor
    listBtn.TextScaled = true
    listBtn.Font = Enum.Font.GothamBold
    listBtn.ZIndex = 5
    listBtn.ClipsDescendants = true
    listBtn.Parent = container
    local lbc = Instance.new("UICorner"); lbc.CornerRadius = UDim.new(0,7); lbc.Parent = listBtn
    if getGlow() then
        local glow = Instance.new("UIStroke"); glow.Color = color; glow.Thickness = 2; glow.Transparency = 0.5; glow.Parent = listBtn
    end

    local actionRow = Instance.new("Frame")
    actionRow.Size = UDim2.new(0, 92, 1, 0)
    actionRow.Position = UDim2.new(1, -95, 0, 0)
    actionRow.BackgroundTransparency = 1
    actionRow.ZIndex = 5
    actionRow.Parent = container
    local arLyt = Instance.new("UIListLayout")
    arLyt.FillDirection = Enum.FillDirection.Horizontal
    arLyt.Padding = UDim.new(0,2)
    arLyt.VerticalAlignment = Enum.VerticalAlignment.Center
    arLyt.HorizontalAlignment = Enum.HorizontalAlignment.Right
    arLyt.Parent = actionRow

    local function mkABtn(txt, bg)
        local b = Instance.new("TextButton")
        b.Size = UDim2.new(0,24,0,24)
        b.BackgroundColor3 = bg
        b.BorderSizePixel = 0
        b.Text = txt
        b.TextColor3 = Color3.fromRGB(220,200,255)
        b.TextScaled = true
        b.Font = Enum.Font.GothamBold
        b.ZIndex = 6
        b.Parent = actionRow
        local bc = Instance.new("UICorner"); bc.CornerRadius = UDim.new(0,6); bc.Parent = b
        return b
    end

    local pinBtn = mkABtn("📌", Color3.fromRGB(100,75,20))
    local popBtn = mkABtn("↗", Color3.fromRGB(22,62,155))
    local editBtn = mkABtn("✎", Color3.fromRGB(22,95,50))
    local delBtn = mkABtn("✕", Color3.fromRGB(145,15,50))

    local floatingBtn = Instance.new("TextButton")
    floatingBtn.Size = UDim2.new(0, width, 0, 34)
    floatingBtn.Position = UDim2.new(0.5, -width/2, 0.85, 0)
    floatingBtn.BackgroundColor3 = color
    floatingBtn.BorderSizePixel = 0
    floatingBtn.Text = displayName
    floatingBtn.TextColor3 = textColor
    floatingBtn.TextScaled = true
    floatingBtn.Font = Enum.Font.GothamBold
    floatingBtn.ZIndex = 10
    floatingBtn.Visible = false
    floatingBtn.ClipsDescendants = true
    floatingBtn.Parent = screenGui
    local fbc = Instance.new("UICorner"); fbc.CornerRadius = UDim.new(0,9); fbc.Parent = floatingBtn
    local fbs = Instance.new("UIStroke"); fbs.Color = Color3.fromRGB(200,170,255); fbs.Thickness = 1.5; fbs.Parent = floatingBtn
    if getGlow() then
        local fg = Instance.new("UIStroke"); fg.Color = color; fg.Thickness = 3; fg.Transparency = 0.45; fg.Parent = floatingBtn
    end
    if not getLock() then makeDraggable(floatingBtn) end

    local function executeScript()
        local ok, err = pcall(function()
            local fn = loadstring(script)
            if fn then fn() end
        end)
        addHistoryEntry(name, ok, color)
        if not ok then
            showNotif("❌ Error: "..tostring(err):sub(1,36), Color3.fromRGB(200,40,40), 4)
        else
            showNotif("✦ "..name.." executed!", color)
        end
    end

    floatingBtn.MouseEnter:Connect(function()
        showTooltipUI(tooltip, floatingBtn.AbsolutePosition + Vector2.new(width/2, 0))
        if not getLock() then
            TweenService:Create(floatingBtn, TweenInfo.new(0.15), {Size = UDim2.new(0, width+8, 0, 38)}):Play()
        end
    end)
    floatingBtn.MouseLeave:Connect(function()
        hideTooltipUI()
        TweenService:Create(floatingBtn, TweenInfo.new(0.15), {Size = UDim2.new(0, width, 0, 34)}):Play()
    end)
    floatingBtn.MouseButton1Click:Connect(function()
        ripple(floatingBtn, UserInputService:GetMouseLocation().X, UserInputService:GetMouseLocation().Y)
        executeScript()
    end)
    listBtn.MouseButton1Click:Connect(function()
        ripple(listBtn, UserInputService:GetMouseLocation().X, UserInputService:GetMouseLocation().Y)
        executeScript()
    end)

    pinBtn.MouseButton1Click:Connect(function()
        local pidx = table.find(pinnedButtons, id)
        if pidx then
            table.remove(pinnedButtons, pidx)
            pinBtn.BackgroundColor3 = Color3.fromRGB(100,75,20)
            showNotif("📌 '"..name.."' unpinned!", getT().accent)
        else
            table.insert(pinnedButtons, id)
            pinBtn.BackgroundColor3 = Color3.fromRGB(200,150,20)
            showNotif("📌 '"..name.."' pinned!", Color3.fromRGB(200,150,20))
        end
        updatePinBar()
    end)

    if table.find(pinnedButtons, id) then
        pinBtn.BackgroundColor3 = Color3.fromRGB(200,150,20)
    end

    popBtn.MouseButton1Click:Connect(function()
        local isVis = floatingBtn.Visible
        if not isVis then
            floatingBtn.Size = UDim2.new(0,0,0,0)
            floatingBtn.Visible = true
            TweenService:Create(floatingBtn, TweenInfo.new(0.3, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Size = UDim2.new(0,width,0,34)}):Play()
            showNotif("↗ '"..name.."' popped out!", Color3.fromRGB(22,62,155))
        else
            TweenService:Create(floatingBtn, TweenInfo.new(0.15), {Size = UDim2.new(0,0,0,0)}):Play()
            task.delay(0.18, function() floatingBtn.Visible = false end)
            showNotif("✦ '"..name.."' hidden!", getT().accent)
        end
    end)

    editBtn.MouseButton1Click:Connect(function()
        btnNameInput.Text = name
        btnScriptInput.Text = script
        sizeInput.Text = tostring(math.floor(width/buttonScale))
        iconInput.Text = icon
        tooltipInput.Text = tooltip
        hotkeyInput.Text = hotkey
        tagInput.Text = tag
        switchTab("Create")
        showNotif("✎ Editing '"..name.."'  —  recreate to apply!", Color3.fromRGB(22,95,50), 3.5)
    end)

    local btnData = {
        id=id, name=name, script=script, color=color,
        textColor=textColor, width=math.floor(width/buttonScale),
        icon=icon, tooltip=tooltip, hotkey=hotkey, tag=tag,
        container=container, floatingBtn=floatingBtn
    }

    delBtn.MouseButton1Click:Connect(function()
        local doDelete = function()
            local snapshot = {
                id=id, name=name, script=script, color=color,
                textColor=textColor, width=math.floor(width/buttonScale),
                icon=icon, tooltip=tooltip, hotkey=hotkey, tag=tag
            }
            table.insert(undoStack, snapshot)
            redoStack = {}
            if #undoStack > 15 then table.remove(undoStack,1) end
            for i,v in ipairs(customButtons) do
                if v.id == id then table.remove(customButtons,i) break end
            end
            local pi = table.find(pinnedButtons, id)
            if pi then table.remove(pinnedButtons, pi) updatePinBar() end
            if hotkey ~= "" then hotkeys[hotkey] = nil updateHotkeyList() end
            TweenService:Create(container, TweenInfo.new(0.2), {BackgroundTransparency=1, Size=UDim2.new(1,-4,0,0)}):Play()
            task.delay(0.22, function()
                if floatingBtn and floatingBtn.Parent then floatingBtn:Destroy() end
                if container and container.Parent then container:Destroy() end
                updateScroll()
                refreshGroupBar()
            end)
            showNotif("🗑️ '"..name.."' deleted! (↩ undo)", Color3.fromRGB(148,16,52))
        end
        if getConfirm() then
            delBtn.Text = "?"
            delBtn.BackgroundColor3 = Color3.fromRGB(220,80,20)
            task.delay(0.05, function()
                local conn3
                conn3 = delBtn.MouseButton1Click:Connect(function()
                    conn3:Disconnect()
                    delBtn.Text = "✕"
                    delBtn.BackgroundColor3 = Color3.fromRGB(145,15,50)
                    doDelete()
                end)
                task.delay(3, function()
                    if delBtn and delBtn.Parent then
                        delBtn.Text = "✕"
                        delBtn.BackgroundColor3 = Color3.fromRGB(145,15,50)
                        pcall(function() conn3:Disconnect() end)
                    end
                end)
            end)
        else
            doDelete()
        end
    end)

    if hotkey ~= "" then
        hotkeys[hotkey] = {name=name, func=executeScript, color=color}
        updateHotkeyList()
    end

    table.insert(customButtons, btnData)
    table.insert(floatingBtns, floatingBtn)
    updateScroll()
    refreshGroupBar()

    container.Size = UDim2.new(1,-4,0,0)
    TweenService:Create(container, TweenInfo.new(0.3, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Size = UDim2.new(1,-4,0,rh)}):Play()

    return btnData
end

undoBtn2.MouseButton1Click:Connect(function()
    if #undoStack == 0 then showNotif("⚠️ Nothing to undo!", Color3.fromRGB(180,120,20)) return end
    local last = table.remove(undoStack)
    table.insert(redoStack, last)
    createCustomButton(last)
    showNotif("↩ Restored '"..last.name.."'!", Color3.fromRGB(22,55,138))
end)

redoBtn.MouseButton1Click:Connect(function()
    if #redoStack == 0 then showNotif("⚠️ Nothing to redo!", Color3.fromRGB(180,120,20)) return end
    local last = table.remove(redoStack)
    for i,v in ipairs(customButtons) do
        if v.id == last.id then
            if v.floatingBtn and v.floatingBtn.Parent then v.floatingBtn:Destroy() end
            if v.container and v.container.Parent then v.container:Destroy() end
            table.remove(customButtons, i)
            break
        end
    end
    updateScroll()
    showNotif("↪ Redo applied!", Color3.fromRGB(22,85,55))
end)

