        if td.trail then table.insert(fxStr, "Trail") end
        if td.sparkle then table.insert(fxStr, "Sparkle") end
        if td.fire then table.insert(fxStr, "Fire") end
        if td.smoke then table.insert(fxStr, "Smoke") end
        if td.light then table.insert(fxStr, "Light") end

        local fxL = Instance.new("TextLabel", card)
        fxL.Size = UDim2.new(0.62, 0, 0, 14)
        fxL.Position = UDim2.new(0, 16, 0, 62)
        fxL.BackgroundTransparency = 1
        fxL.Text = #fxStr > 0 and "FX: " .. table.concat(fxStr, ", ") or "FX: None"
        fxL.TextColor3 = Color3.fromRGB(130, 80, 200)
        fxL.TextSize = 9
        fxL.Font = Enum.Font.Gotham
        fxL.TextXAlignment = Enum.TextXAlignment.Left
        fxL.TextTruncate = Enum.TextTruncate.AtEnd
        fxL.ZIndex = 13

        local editBtn = Instance.new("TextButton", card)
        editBtn.Size = UDim2.new(0, 60, 0, 25)
        editBtn.Position = UDim2.new(1, -68, 0, 6)
        editBtn.BackgroundColor3 = Color3.fromRGB(60, 0, 150)
        editBtn.BorderSizePixel = 0
        editBtn.Text = "✏️ Edit"
        editBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
        editBtn.TextSize = 10
        editBtn.Font = Enum.Font.GothamBold
        editBtn.ZIndex = 14
        Instance.new("UICorner", editBtn).CornerRadius = UDim.new(0, 7)

        local reBtn = Instance.new("TextButton", card)
        reBtn.Size = UDim2.new(0, 60, 0, 25)
        reBtn.Position = UDim2.new(1, -68, 0, 35)
        reBtn.BackgroundColor3 = Color3.fromRGB(15, 75, 190)
        reBtn.BorderSizePixel = 0
        reBtn.Text = "♻️ Re-add"
        reBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
        reBtn.TextSize = 9
        reBtn.Font = Enum.Font.GothamBold
        reBtn.ZIndex = 14
        Instance.new("UICorner", reBtn).CornerRadius = UDim.new(0, 7)

        local delBtn = Instance.new("TextButton", card)
        delBtn.Size = UDim2.new(0, 60, 0, 25)
        delBtn.Position = UDim2.new(1, -68, 0, 64)
        delBtn.BackgroundColor3 = Color3.fromRGB(165, 10, 48)
        delBtn.BorderSizePixel = 0
        delBtn.Text = "🗑️ Hapus"
        delBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
        delBtn.TextSize = 9
        delBtn.Font = Enum.Font.GothamBold
        delBtn.ZIndex = 14
        Instance.new("UICorner", delBtn).CornerRadius = UDim.new(0, 7)

        local idx = i
        editBtn.MouseButton1Click:Connect(function()
            loadToEdit(idx)
        end)
        reBtn.MouseButton1Click:Connect(function()
            if toolsList[idx] and toolsList[idx].tool then
                if toolsList[idx].tool.Parent ~= LocalPlayer.Backpack then
                    toolsList[idx].tool.Parent = LocalPlayer.Backpack
                end
                forceVisible(toolsList[idx].tool)
                task.spawn(showNotif, "♻️ '" .. toolsList[idx].name .. "' ditambah kembali!", Color3.fromRGB(100, 200, 255))
                updateManage()
            end
        end)
        delBtn.MouseButton1Click:Connect(function()
            if toolsList[idx] and toolsList[idx].tool then
                local n = toolsList[idx].name
                toolsList[idx].tool:Destroy()
                table.remove(toolsList, idx)
                if currentEditIdx == idx then currentEditIdx = nil end
                task.spawn(showNotif, "🗑️ '" .. n .. "' dihapus!", Color3.fromRGB(255, 120, 120))
                updateManage()
            end
        end)
    end

    mkDivider(managePage)
    local delAllBtn = mkButton("🗑️ Hapus Semua Tools", Color3.fromRGB(140, 10, 40), managePage)
    delAllBtn.MouseButton1Click:Connect(function()
        for _, td in pairs(toolsList) do
            if td.tool and td.tool.Parent then td.tool:Destroy() end
        end
        toolsList = {}
        currentEditIdx = nil
        task.spawn(showNotif, "🗑️ Semua tool dihapus!", Color3.fromRGB(255, 120, 120))
        updateManage()
    end)

    local reAddAllBtn = mkButton("♻️ Re-add Semua ke Backpack", Color3.fromRGB(15, 75, 190), managePage)
    reAddAllBtn.MouseButton1Click:Connect(function()
        for _, td in pairs(toolsList) do
            if td.tool then
                td.tool.Parent = LocalPlayer.Backpack
                forceVisible(td.tool)
            end
        end
        task.spawn(showNotif, "♻️ Semua tool ditambah kembali!", Color3.fromRGB(100, 200, 255))
        updateManage()
    end)
end

