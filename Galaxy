local function mkSlider(label, min, max, default, parent)
    local cont = Instance.new("Frame", parent)
    cont.Size = UDim2.new(1, -16, 0, 58)
    cont.BackgroundTransparency = 1
    cont.ZIndex = 12

    local lbl = Instance.new("TextLabel", cont)
    lbl.Size = UDim2.new(1, 0, 0, 20)
    lbl.BackgroundTransparency = 1
    lbl.Text = label .. ": " .. tostring(default)
    lbl.TextColor3 = Color3.fromRGB(195, 150, 255)
    lbl.TextSize = 11
    lbl.Font = Enum.Font.Gotham
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.ZIndex = 12

    local track = Instance.new("Frame", cont)
    track.Size = UDim2.new(1, 0, 0, 14)
    track.Position = UDim2.new(0, 0, 0, 26)
    track.BackgroundColor3 = Color3.fromRGB(18, 0, 50)
    track.BorderSizePixel = 0
    track.ZIndex = 12
    Instance.new("UICorner", track).CornerRadius = UDim.new(1, 0)

    local pct = (default - min) / (max - min)

    local fill = Instance.new("Frame", track)
    fill.Size = UDim2.new(pct, 0, 1, 0)
    fill.BackgroundColor3 = Color3.fromRGB(125, 35, 225)
    fill.BorderSizePixel = 0
    fill.ZIndex = 13
    Instance.new("UICorner", fill).CornerRadius = UDim.new(1, 0)
    local fg = Instance.new("UIGradient", fill)
    fg.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, Color3.fromRGB(190, 90, 255)),
        ColorSequenceKeypoint.new(1, Color3.fromRGB(95, 15, 195))
    })

    local knob = Instance.new("Frame", track)
    knob.Size = UDim2.new(0, 22, 0, 22)
    knob.Position = UDim2.new(pct, -11, 0.5, -11)
    knob.BackgroundColor3 = Color3.fromRGB(200, 100, 255)
    knob.BorderSizePixel = 0
    knob.ZIndex = 14
    Instance.new("UICorner", knob).CornerRadius = UDim.new(1, 0)
    local kg = Instance.new("UIGradient", knob)
    kg.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, Color3.fromRGB(255, 160, 255)),
        ColorSequenceKeypoint.new(1, Color3.fromRGB(145, 25, 215))
    })
    kg.Rotation = 135

    local val = default
    local sliding = false

    knob.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
            sliding = true
        end
    end)
    UserInputService.InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
            sliding = false
        end
    end)
    UserInputService.InputChanged:Connect(function(i)
        if sliding and (i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch) then
            local ap = track.AbsolutePosition
            local as = track.AbsoluteSize
            local rx = math.clamp((i.Position.X - ap.X) / as.X, 0, 1)
            val = math.round(min + (max - min) * rx)
            fill.Size = UDim2.new(rx, 0, 1, 0)
            knob.Position = UDim2.new(rx, -11, 0.5, -11)
            lbl.Text = label .. ": " .. tostring(val)
        end
    end)
    track.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
            local ap = track.AbsolutePosition
            local as = track.AbsoluteSize
            local rx = math.clamp((i.Position.X - ap.X) / as.X, 0, 1)
            val = math.round(min + (max - min) * rx)
            fill.Size = UDim2.new(rx, 0, 1, 0)
            knob.Position = UDim2.new(rx, -11, 0.5, -11)
            lbl.Text = label .. ": " .. tostring(val)
            sliding = true
        end
    end)

    return {
        get = function() return val end,
        set = function(v)
            val = math.clamp(v, min, max)
            local rx = (val - min) / (max - min)
            fill.Size = UDim2.new(rx, 0, 1, 0)
            knob.Position = UDim2.new(rx, -11, 0.5, -11)
            lbl.Text = label .. ": " .. tostring(val)
        end
    }
end

