local function switchTab(name)
    currentTab = name
    for n, tb in pairs(tabs) do
        if n == name then
            TweenService:Create(tb, TweenInfo.new(0.18), {BackgroundColor3 = getT().accent}):Play()
            tb.TextColor3 = Color3.fromRGB(255, 255, 255)
            TweenService:Create(tabIndicator, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
                Position = UDim2.new(0, tb.AbsolutePosition.X - tabBar.AbsolutePosition.X, 1, -2),
                Size = UDim2.new(0, tb.AbsoluteSize.X, 0, 2)
            }):Play()
        else
            TweenService:Create(tb, TweenInfo.new(0.18), {BackgroundColor3 = Color3.fromRGB(14, 5, 36)}):Play()
            tb.TextColor3 = Color3.fromRGB(120, 90, 175)
        end
    end
    for n, c in pairs(tabContents) do c.Visible = n == name end
end

