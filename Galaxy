local function makeToggle(parent, label, posY, default, key)
    local row = Instance.new("Frame")
    row.Size = UDim2.new(1,0,0,32)
    row.Position = UDim2.new(0,0,0,posY)
    row.BackgroundColor3 = getT().card
    row.BorderSizePixel = 0
    row.ZIndex = 4
    row.Parent = parent
    local rc = Instance.new("UICorner"); rc.CornerRadius = UDim.new(0,8); rc.Parent = row
    local rs = Instance.new("UIStroke"); rs.Color = Color3.fromRGB(36,14,72); rs.Thickness = 1; rs.Parent = row
    local lbl = Instance.new("TextLabel")
    lbl.Size = UDim2.new(0.73,0,1,0)
    lbl.Position = UDim2.new(0,9,0,0)
    lbl.BackgroundTransparency = 1
    lbl.Text = label
    lbl.TextColor3 = getT().subtext
    lbl.TextScaled = true
    lbl.Font = Enum.Font.Gotham
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.ZIndex = 5
    lbl.Parent = row
    local tf = Instance.new("Frame")
    tf.Size = UDim2.new(0,42,0,20)
    tf.Position = UDim2.new(1,-48,0.5,-10)
    tf.BackgroundColor3 = default and getT().accent or Color3.fromRGB(30,12,50)
    tf.BorderSizePixel = 0
    tf.ZIndex = 5
    tf.Parent = row
    local tfc = Instance.new("UICorner"); tfc.CornerRadius = UDim.new(1,0); tfc.Parent = tf
    local circle = Instance.new("Frame")
    circle.Size = UDim2.new(0,14,0,14)
    circle.Position = default and UDim2.new(1,-17,0.5,-7) or UDim2.new(0,3,0.5,-7)
    circle.BackgroundColor3 = Color3.fromRGB(255,255,255)
    circle.BorderSizePixel = 0
    circle.ZIndex = 6
    circle.Parent = tf
    local cc = Instance.new("UICorner"); cc.CornerRadius = UDim.new(1,0); cc.Parent = circle
    local val = default
    local changed = Instance.new("BindableEvent")
    local togBtn3 = Instance.new("TextButton")
    togBtn3.Size = UDim2.new(1,0,1,0)
    togBtn3.BackgroundTransparency = 1
    togBtn3.Text = ""
    togBtn3.ZIndex = 7
    togBtn3.Parent = tf
    togBtn3.MouseButton1Click:Connect(function()
        val = not val
        if key then settings[key] = val end
        TweenService:Create(tf, TweenInfo.new(0.2), {BackgroundColor3 = val and getT().accent or Color3.fromRGB(30,12,50)}):Play()
        TweenService:Create(circle, TweenInfo.new(0.2), {Position = val and UDim2.new(1,-17,0.5,-7) or UDim2.new(0,3,0.5,-7)}):Play()
        changed:Fire(val)
    end)
    return row, changed.Event, function() return val end
end

