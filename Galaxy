local function refreshGroupBar()
    for _, c in ipairs(gbScroll:GetChildren()) do
        if c:IsA("TextButton") then c:Destroy() end
    end
    groupBtnRefs = {}
    local allGroups = {"All"}
    for _, data in ipairs(customButtons) do
        if data.tag and data.tag ~= "" and not table.find(allGroups, data.tag) then
            table.insert(allGroups, data.tag)
        end
    end
    for _, g in ipairs(allGroups) do
        local gb = Instance.new("TextButton")
        gb.Size = UDim2.new(0, 0, 0, 20)
        gb.AutomaticSize = Enum.AutomaticSize.X
        gb.BackgroundColor3 = g == selectedGroup and getT().accent or Color3.fromRGB(14, 5, 36)
        gb.BorderSizePixel = 0
        gb.Text = " " .. g .. " "
        gb.TextColor3 = Color3.fromRGB(220, 200, 255)
        gb.TextScaled = false
        gb.TextSize = 11
        gb.Font = Enum.Font.GothamBold
        gb.ZIndex = 5
        gb.Parent = gbScroll
        local gbc = Instance.new("UICorner"); gbc.CornerRadius = UDim.new(0,6); gbc.Parent = gb
        table.insert(groupBtnRefs, {btn=gb, group=g})
        gb.MouseButton1Click:Connect(function()
            selectedGroup = g
            refreshGroupBar()
            for _, data in ipairs(customButtons) do
                if data.container and data.container.Parent then
                    local show = selectedGroup == "All" or (data.tag == selectedGroup)
                    local q = searchQuery:lower()
                    if q ~= "" then
                        show = show and (data.name:lower():find(q,1,true) ~= nil or (data.tag and data.tag:lower():find(q,1,true) ~= nil))
                    end
                    data.container.Visible = show
                end
            end
        end)
    end
    local totalW = 0
    for _, ref in ipairs(groupBtnRefs) do
        totalW = totalW + ref.btn.AbsoluteSize.X + 3
    end
    gbScroll.CanvasSize = UDim2.new(0, totalW, 0, 0)
end

